##############################################################################
# Makefile — STM32N6570-DK AI display demo
#
# Requires:
#   STM32CUBE_DIR  = path to STM32CubeN6 firmware package
#   TOOLCHAIN_DIR  = path to arm-gnu-toolchain-15.2.rel1-x86_64-arm-none-eabi
#   STAI_DIR       = path to st_ai_output/ (generated by stedgeai)
#
# Usage:
#   make STM32CUBE_DIR=/opt/STM32CubeN6 \
#        TOOLCHAIN_DIR=/home/pc/sby/demoicair_fixed/tools/arm-gnu-toolchain-15.2.rel1-x86_64-arm-none-eabi \
#        STAI_DIR=/home/pc/sby/enhancedoptimaltransport/st_ai_output
##############################################################################

PROJECT   = sb_display
BUILD_DIR = build

# ── Toolchain ──────────────────────────────────────────────────────────────
TOOLCHAIN_DIR ?= /home/pc/sby/demoicair_fixed/tools/arm-gnu-toolchain-15.2.rel1-x86_64-arm-none-eabi
CROSS      = $(TOOLCHAIN_DIR)/bin/arm-none-eabi-
CC         = $(CROSS)gcc
CXX        = $(CROSS)g++
AS         = $(CROSS)gcc -x assembler-with-cpp
LD         = $(CROSS)gcc
OBJCOPY    = $(CROSS)objcopy
SIZE       = $(CROSS)size

# ── STM32CubeN6 paths ──────────────────────────────────────────────────────
STM32CUBE_DIR ?= /home/pc/sby/STM32CubeN6
HAL_DIR    = $(STM32CUBE_DIR)/Drivers/STM32N6xx_HAL_Driver
CMSIS_DIR  = $(STM32CUBE_DIR)/Drivers/CMSIS
BSP_DIR    = $(STM32CUBE_DIR)/Drivers/BSP/STM32N6570-DK

# ── ST.AI runtime (in ST Edge AI 4.0 install) ──────────────────────────────
STAI_DIR  ?= /home/pc/sby/enhancedoptimaltransport/st_ai_output
STAI_RT    = /home/pc/opt/ST/STEdgeAI/4.0/Middlewares/ST/AI

# ── MCU flags ──────────────────────────────────────────────────────────────
MCU        = -mcpu=cortex-m55 -mthumb -mfloat-abi=hard -mfpu=fpv5-d16
DEFS       = -DSTM32N657xx -DUSE_HAL_DRIVER -DUSE_FULL_LL_DRIVER

# ── Include paths ──────────────────────────────────────────────────────────
INCLUDES  += -ICore/Inc
INCLUDES  += -IApp
INCLUDES  += -I$(STAI_DIR)
INCLUDES  += -I$(STAI_RT)/Inc
INCLUDES  += -I$(STAI_RT)/Npu/ll_aton
INCLUDES  += -I$(HAL_DIR)/Inc
INCLUDES  += -I$(CMSIS_DIR)/Device/ST/STM32N6xx/Include
INCLUDES  += -I$(CMSIS_DIR)/Core/Include
INCLUDES  += -I$(BSP_DIR)

# ── Source files ───────────────────────────────────────────────────────────
# Application
C_SRCS  = Core/Src/main.c
C_SRCS += App/app_ai_display.c

# Generated ST.AI network
C_SRCS += $(STAI_DIR)/network.c

# STM32N6 HAL (add only what you use)
HAL_SRCS  = stm32n6xx_hal.c
HAL_SRCS += stm32n6xx_hal_rcc.c
HAL_SRCS += stm32n6xx_hal_rcc_ex.c
HAL_SRCS += stm32n6xx_hal_gpio.c
HAL_SRCS += stm32n6xx_hal_cortex.c
HAL_SRCS += stm32n6xx_hal_dma.c
HAL_SRCS += stm32n6xx_hal_dma_ex.c
HAL_SRCS += stm32n6xx_hal_xspi.c
HAL_SRCS += stm32n6xx_hal_ltdc.c
HAL_SRCS += stm32n6xx_hal_ltdc_ex.c
C_SRCS  += $(addprefix $(HAL_DIR)/Src/, $(HAL_SRCS))

# BSP board support
BSP_SRCS  = stm32n6570_discovery.c
BSP_SRCS += stm32n6570_discovery_lcd.c
BSP_SRCS += stm32n6570_discovery_bus.c
BSP_SRCS += stm32n6570_discovery_xspi.c
C_SRCS  += $(addprefix $(BSP_DIR)/, $(BSP_SRCS))

# NPU ll_aton runtime C sources (needed by the atonn scheduler at runtime)
NPU_RT_DIR = $(STAI_RT)/Npu/ll_aton
C_SRCS += $(NPU_RT_DIR)/ll_aton.c
C_SRCS += $(NPU_RT_DIR)/ll_aton_cipher.c
C_SRCS += $(NPU_RT_DIR)/ll_aton_dbgtrc.c
C_SRCS += $(NPU_RT_DIR)/ecloader.c

# CMSIS startup + system init
ASM_SRCS  = $(CMSIS_DIR)/Device/ST/STM32N6xx/Source/Templates/gcc/startup_stm32n657xx.s
C_SRCS   += $(CMSIS_DIR)/Device/ST/STM32N6xx/Source/Templates/system_stm32n6xx_ns.c

# ST.AI runtime library (CM55 GCC variant — verified present on this machine)
STAI_LIB  = $(STAI_RT)/Lib/GCC/ARMCortexM55/NetworkRuntime1200_CM55_GCC.a

# ── Compiler flags ─────────────────────────────────────────────────────────
CFLAGS  = $(MCU) $(DEFS) $(INCLUDES)
CFLAGS += -O2 -Wall -ffunction-sections -fdata-sections -std=c11
CFLAGS += -fstack-usage

ASFLAGS = $(MCU) $(DEFS) $(INCLUDES) -Wall -fdata-sections -ffunction-sections

# ── Linker flags ───────────────────────────────────────────────────────────
LDFLAGS  = $(MCU)
LDFLAGS += -TLinker/STM32N6570_APP.ld
LDFLAGS += -Wl,--gc-sections
LDFLAGS += -Wl,-Map=$(BUILD_DIR)/$(PROJECT).map,--cref
LDFLAGS += -lm -lc -lnosys
LDFLAGS += $(STAI_LIB)

# ── Object files ───────────────────────────────────────────────────────────
OBJS  = $(addprefix $(BUILD_DIR)/, $(notdir $(C_SRCS:.c=.o)))
OBJS += $(addprefix $(BUILD_DIR)/, $(notdir $(ASM_SRCS:.s=.o)))

vpath %.c $(sort $(dir $(C_SRCS)))
vpath %.s $(sort $(dir $(ASM_SRCS)))

# ── Build rules ────────────────────────────────────────────────────────────
.PHONY: all clean flash_app flash_weights size

all: $(BUILD_DIR)/$(PROJECT).bin $(BUILD_DIR)/$(PROJECT).hex
	@echo "Build complete."
	$(SIZE) $(BUILD_DIR)/$(PROJECT).elf

$(BUILD_DIR)/%.o: %.c | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/%.o: %.s | $(BUILD_DIR)
	$(AS) $(ASFLAGS) -c $< -o $@

$(BUILD_DIR)/$(PROJECT).elf: $(OBJS)
	$(LD) $(LDFLAGS) $^ -o $@

$(BUILD_DIR)/$(PROJECT).bin: $(BUILD_DIR)/$(PROJECT).elf
	$(OBJCOPY) -O binary $< $@

$(BUILD_DIR)/$(PROJECT).hex: $(BUILD_DIR)/$(PROJECT).elf
	$(OBJCOPY) -O ihex $< $@

$(BUILD_DIR):
	mkdir -p $@

# ── Flash commands (ST-LINK via STM32CubeProgrammer CLI) ───────────────────
PROGRAMMER = STM32_Programmer_CLI
STLINK     = --connect port=SWD freq=8000 reset=HWrst

# Flash application binary at 0x70100000
flash_app: $(BUILD_DIR)/$(PROJECT).bin
	$(PROGRAMMER) $(STLINK) --download $< 0x70100000 --verify --go

# Flash weights at 0x71000000 (separate flash bank / region)
flash_weights:
	$(PROGRAMMER) $(STLINK) \
	  --download $(STAI_DIR)/network_data.bin 0x71000000 --verify

# Full flash: weights first, then app
flash: flash_weights flash_app

clean:
	rm -rf $(BUILD_DIR)
